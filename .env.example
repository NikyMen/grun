# Clave secreta para firmar las sesiones (cambiar en produccion)
AUTH_SECRET=cambia-esta-clave-por-una-larga-y-aleatoria

# Usuario administrador inicial (se crea al iniciar la base por primera vez)
ADMIN_EMAIL=admin@grun.com
ADMIN_PASSWORD=grun2026

# Clave de la API de OpenAI (ChatGPT) para el chat y las recomendaciones de IA
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# (Opcional) Modelo de OpenAI a usar. Por defecto: gpt-4o
# OPENAI_MODEL=gpt-4o
